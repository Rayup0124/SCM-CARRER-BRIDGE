# API URL - used by Vercel frontend to call the Railway backend
# Development (localhost):
VITE_API_URL=http://localhost:4000/api

# Production (Vercel + Railway) - Railway will give you a URL like:
# https://your-app.railway.app
# Uncomment and fill in your Railway URL before deploying to Vercel:
# VITE_API_URL=https://your-backend-name.railway.app/api

# Cloudinary (for file uploads) - get these from your Cloudinary dashboard:
# https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
