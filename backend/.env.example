# SCM Career Bridge - Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/scm-career-bridge?appName=Cluster0

# Supabase (for Storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=replace-this-with-a-long-random-string-min-32-chars

# Server
PORT=4000

# Frontend URL (for CORS) — replace with Vercel URL after frontend deployment
FRONTEND_URL=http://localhost:5173
